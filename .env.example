# =====================================================================
# ELS Tracker — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.
# =====================================================================

# --- Supabase (created in M0-handoff) ------------------------------------
# Get these from https://supabase.com/dashboard/project/_/settings/api
# The public URL + anon key are safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — NEVER exposed to the browser. Server/API routes only.
# Used by OCR workers, admin operations, and migrations.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google AI / Gemini 2.5 Flash (used from M6 onward) ------------------
# Get a free-tier key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- hCaptcha (M6: signup spam protection) -------------------------------
# Free tier: https://www.hcaptcha.com/
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=
